# ── LLM 端点（独立运行层用；只当 MCP 后端时可不填）──
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.8        # 叙事温度，0.7~0.9 较稳
LLM_MAX_TOKENS=2048        # 单次回复上限

# ── 上下文压缩（独立运行 agent loop；引擎才是长程记忆，历史可激进裁剪）──
HISTORY_CHAR_BUDGET=40000  # 历史超此字符数才压缩；设 0 关闭压缩
KEEP_RECENT_TURNS=6        # 至少完整保留最近 N 个玩家回合
OLD_TOOL_RESULT_CAP=600    # 旧回合工具结果截断长度（最新一轮保留完整）

DEBUG=false
